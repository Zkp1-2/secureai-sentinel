# SecureAI Sentinel environment config

# Keep false for deterministic local mode. Set true only after configuring an LLM provider.
USE_LLM=false

# rule | openai | ollama
LLM_PROVIDER=rule

# OpenAI option
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama option
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

LLM_TIMEOUT_SECONDS=45
KNOWLEDGE_BASE_DIR=backend/data/knowledge_base
